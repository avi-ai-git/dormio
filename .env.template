# ============================================================
# Dormio environment variables
# Copy this file to .env and fill in the keys you have. Never
# commit .env. The app runs with no keys at all, it just falls
# back to the plain facts and skips the web search.
# ============================================================

# Chat model providers. You need at least one. The default chat model
# is Claude Haiku through OpenRouter. Mistral also runs the input
# moderation, so a Mistral key is worth having even with another model.
OPENROUTER_API_KEY=""
MISTRAL_API_KEY=""
OLLAMA_API_KEY=""

# Web search for the overland last mile the curated data does not cover.
# Optional. Serper is tried first, then SerpApi, then Tavily.
SERPER_API_KEY=""
SERPAPI_API_KEY=""
TAVILY_API_KEY=""

# Tracing with Langfuse. Optional. Leave blank to run without it.
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"
