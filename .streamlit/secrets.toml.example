# Streamlit Cloud secrets template.
# On share.streamlit.io, open the app's Settings, then Secrets, and paste these
# with real values. The keys match .env, and app.py bridges them into the
# environment automatically. Do not commit the real secrets.toml.

OPENROUTER_API_KEY = "sk-or-v1-..."
OPENROUTER_BASE_URL = "https://openrouter.ai/api/v1"
MISTRAL_API_KEY = "..."
MISTRAL_BASE_URL = "https://api.mistral.ai/v1"
OLLAMA_API_KEY = "..."
OLLAMA_BASE_URL = "https://api.ollama.com"
DEFAULT_RUNTIME_MODEL = "claude-haiku-4.5"

LANGFUSE_PUBLIC_KEY = "pk-lf-..."
LANGFUSE_SECRET_KEY = "sk-lf-..."
LANGFUSE_HOST = "https://cloud.langfuse.com"
LANGFUSE_PROJECT = "dormio"
